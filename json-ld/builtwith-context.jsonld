      "@id": "bw:companyName",
      "@type": "xsd:string"
    },
    "identifiers": {
      "@id": "bw:identifiers",
      "@container": "@set"
    },
    "identifierType": {
      "@id": "bw:identifierType",
      "@type": "xsd:string"
    },
    "identifierValue": {
      "@id": "bw:identifierValue",
      "@type": "xsd:string"
    },
    "matches": {
      "@id": "bw:matches",
      "@container": "@set"
    },
    "overlap": {
      "@id": "bw:overlap",
      "@type": "xsd:boolean"
    },
