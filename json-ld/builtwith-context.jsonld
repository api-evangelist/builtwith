      "@id": "bw:paths",
      "@container": "@set"
    },
    "groups": {
      "@id": "bw:groups",
      "@container": "@set"
    },
    "results": {
      "@id": "bw:results",
      "@container": "@set"
    },
    "nextOffset": {
      "@id": "bw:nextOffset",
      "@type": "xsd:string"
    },
    "spend": {
      "@id": "bw:spend",
      "@type": "xsd:decimal"
    },
    "revenue": {
      "@id": "bw:revenue",
      "@type": "xsd:decimal"
    },
    "followers": {
      "@id": "bw:followers",
      "@type": "xsd:integer"
    },
    "employees": {
      "@id": "bw:employees",
      "@type": "xsd:integer"
